# Build artifacts.
# Anchored per-project so we never match a Java/Groovy package dir named
# `build` (e.g. com/calc/build/). Add new subprojects here as they appear.
/build/
/buildSrc/build/
/calc-core/build/
/render-engine/build/
/jni-bridge/build/
/native-app/build/
/java-wrapper/build/
*.o
*.so
*.dll
*.dylib
*.exe
*.out
*.obj
*.lib
*.a

# Third-party (downloaded by setup.sh)
third_party/imgui/

# Font build artifacts
fonts/subset_chars.txt
fonts/NotoSansSC-VF.ttf

# IDE
.idea/
.vscode/
*.iml
.clangd/
compile_commands.json

# OS
.DS_Store
Thumbs.db

# Gradle
.gradle/
# NOTE: gradle/wrapper/gradle-wrapper.jar IS committed — it is required for
# ./gradlew to work on a fresh checkout. Do NOT ignore it.

# Fault-tolerant toolchain cache (re-provisioned by tools/toolchain-ensure.sh)
.scicalc-cache/

# Secrets — NEVER commit credentials
.gh_pat
*.pat
.pat_token
encoded.txt
.local/

# Third-party source archives
third_party/gmp-*.tar.xz
third_party/mpfr-*.tar.xz
third_party/glfw-*.tar.gz

# Third-party source directories (can be re-downloaded)
third_party/gmp-6.*/
third_party/mpfr-4.*/
third_party/glfw-3.4/

# Built dependencies
.local/
tool-results/
upload/

# Stray apt downloads
*.deb
